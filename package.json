{
  "name": "anchor-tool",
  "version": "1.0.0",
  "scripts": {
    "build": "npx esbuild src/main.ts --bundle --outfile=dist/bundle.js --sourcemap --define:process.env.SUPABASE_URL=\"\\\"$SUPABASE_URL\\\"\" --define:process.env.SUPABASE_ANON_KEY=\"\\\"$SUPABASE_ANON_KEY\\\"\"",
    "watch": "npx esbuild src/main.ts --bundle --outfile=dist/bundle.js --sourcemap --watch",
    "serve": "npx serve -l 3000 ."
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0"
  }
}